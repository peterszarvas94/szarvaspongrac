---
import { Trash, BookImage, ChevronUp, ChevronDown } from "@lucide/astro";
import { ImageOff } from "lucide-astro";

export interface Props {
  key: string;
}

const { key } = Astro.props;
---

{/* image gallery */}
<div
  id="image-gallery"
  data-images={key}
  class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
>
</div>

{/* empty */}
<template id="empty-gallery-template">
  <div
    id="empty-gallery"
    class="w-full flex flex-col gap-4 items-center justify-center"
  >
    <ImageOff class="size-10 text-base-content opacity-60" />
    <p class="text-lg">Nincs kép feltöltve</p>
  </div>
</template>

{/* image template */}
<template id="image-gallery-item">
  <div
    data-id="id"
    data-sorting="0"
    data-cover="false"
    class="relative block"
  >
    {/* image button */}
    <button
      commandfor="image-popover"
      command="show-popover"
      data-url="url"
      class="mx-auto flex h-full w-full max-h-60 max-w-60 items-center justify-center cursor-pointer border-0 bg-transparent p-0"
      type="button"
      aria-label="Kép megnyitása"
      title="Kép megnyitása"
    >
      <img
        src="src"
        alt="alt"
        width={200}
        height={250}
        class="max-h-full max-w-full h-auto w-auto object-contain rounded-lg shadow-lg hover:shadow-xl"
        loading="lazy"
      />
    </button>

    {/* other buttons */}
    <div
      data-auth="true"
      data-edit="true"
      class="hidden absolute top-2 left-2 right-2 flex justify-between"
    >
      <div class="join">
        <button
          data-cover="id"
          class="join-item btn btn-sm btn-square"
          title="Borítóképnek jelölés"
        >
          <BookImage class="size-4" />
        </button>
        <button
          data-delete=""
          class="join-item btn btn-sm btn-square"
          title="Törlés"
        >
          <Trash class="size-4" />
        </button>
      </div>
    </div>

    {/* drop zones */}
    <div
      class="absolute -left-6 top-1/2 -translate-y-1/2 h-30 w-6"
      data-drop-before="0"
    >
      <div
        class="pointer-events-none absolute left-1/2 top-0 h-full w-1 -translate-x-1/2 rounded-full bg-base-content opacity-0 transition-opacity"
        data-drop-line
      >
      </div>
    </div>
    <div
      class="absolute -right-6 top-1/2 -translate-y-1/2 h-30 w-6"
      data-drop-after="0"
    >
      <div
        class="pointer-events-none absolute left-1/2 top-0 h-full w-1 -translate-x-1/2 rounded-full bg-base-content opacity-0 transition-opacity"
        data-drop-line
      >
      </div>
    </div>
  </div>
</template>
